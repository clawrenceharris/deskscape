generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  userId       String     @unique
  username     String     @unique
  displayName  String?
  votes        Vote[]
  avatarUrl    String?
  schoolId     String?
  school       School?    @relation(fields: [schoolId], references: [id])
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  avatarPath   String?
  createdDesks Desk[]     @relation("DeskCreator") // desks this profile created
  memberships  Member[] // desks this profile is a member of
  notebooks    Notebook[]
  materials    Material[] // materials this profile has created
  downloads    Download[]

  @@index([schoolId])
}

model Desk {
  id          String     @id @default(cuid())
  creatorId   String
  name        String
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  schoolId    String
  description String?
  imageUrl    String?
  imagePath   String?
  isPublic    Boolean    @default(false)
  school      School     @relation(fields: [schoolId], references: [id])
  creator     Profile    @relation("DeskCreator", fields: [creatorId], references: [userId])
  members     Member[]    // profiles that are members of this desk
  notebooks   Notebook[] // notebooks in this desk

  @@index([creatorId])
  @@index([schoolId])
}

model Member {
  id        String     @id @default(cuid())
  profileId String
  deskId    String
  profile   Profile    @relation(fields: [profileId], references: [userId], onDelete: Cascade)
  desk      Desk       @relation(fields: [deskId], references: [id], onDelete: Cascade)
  role      MemberRole @default(VIEWER)

  @@unique([profileId, deskId])
  @@index([profileId])
  @@index([deskId])
}

model Download {
  userId     String  @unique
  profile    Profile @relation(fields: [userId], references: [userId], onDelete: NoAction)
  notebookId String
  createdAt  DateTime @default(now()) @map("created_at")
  notebook   Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  @@id([userId, notebookId])
  @@index([notebookId])
  @@index([userId])
}

model School {
  id       String    @id @default(cuid())
  name     String
  students Profile[] // profiles in this school
  desks    Desk[] // desks in this school

  @@index([name])
}


model Notebook {
  id          String     @id @default(cuid())
  deskId      String
  desk        Desk       @relation(fields: [deskId], references: [id], onDelete: Cascade)
  title       String
  description String?
  materials   Material[] // files in this notebook
  creatorId   String
  creator     Profile    @relation(fields: [creatorId], references: [userId], onDelete: Cascade)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  votes       Vote[]
  downloads   Download[]

  @@index([creatorId])
  @@index([deskId])
  @@index([createdAt])
  @@index([updatedAt])
}

model Vote {
  userId     String
  notebookId String
  profile    Profile  @relation(fields: [userId], references: [userId], onDelete: Cascade)
  isUpvote   Boolean  @default(true)
  notebook   Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)


  @@id([userId, notebookId])
  @@index([userId])
}

model Material {
  id         String       @id @default(cuid())
  notebookId String
  url        String
  path       String
  type       MaterialType
  authorId   String
  author     Profile      @relation(fields: [authorId], references: [userId], onDelete: Cascade)
  title      String?
  fileName   String?
  mimeType   String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  notebook   Notebook     @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  @@index([authorId])
  @@index([notebookId])
}

enum MemberRole {
  VIEWER
  CONTRIBUTOR
  OWNER
}

enum MaterialType {
  NOTES
  WORKSHEET
  QUIZ
  STUDY_GUIDE
  OTHER
}
